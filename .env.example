# App Secrets & Configuration
NODE_ENV=development

# Application URLs
# Production: https://ads.lamanify.com
# Development: http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database Setup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lamaniads?schema=public

# Redis Setup (Queue and Cache)
REDIS_URL=redis://localhost:6379/0

# Platform Connection Details (OAuth / Dev Tokens)
META_APP_ID=mock_meta_app_id
META_CLIENT_SECRET=mock_meta_client_secret
GOOGLE_DEVELOPER_TOKEN=mock_google_developer_token
GOOGLE_CLIENT_ID=mock_google_client_id
GOOGLE_CLIENT_SECRET=mock_google_client_secret

# Encryption Secrets
ENCRYPTION_KEY=32_byte_hex_string_for_libsodium_envelope_encryption

# Service Hosts & Ports
API_PORT=8000
WEB_PORT=3000
MCP_PORT=4000
